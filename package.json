{
    "name": "template-c1",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev --turbopack",
        "build": "next build",
        "start": "next start",
        "lint": "next lint",
        "typecheck": "tsc --noEmit",
        "setup-hooks": "git config core.hooksPath scripts/githooks",
        "dev:clean": "npx rimraf .next && npm run dev",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:unit": "vitest run tests/unit",
        "test:integration": "vitest run tests/integration",
        "test:e2e": "playwright test",
        "test:e2e:finance": "playwright test tests/e2e/finance-workflow.spec.ts",
        "test:e2e:fleet": "playwright test tests/e2e/fleet-workflow.spec.ts",
        "test:e2e:rac": "playwright test tests/e2e/rac-workflow.spec.ts",
        "test:e2e:admin": "playwright test tests/e2e/admin-workflow.spec.ts",
        "test:e2e:cross": "playwright test tests/e2e/cross-module.spec.ts",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:debug": "playwright test --debug",
        "test:all": "vitest run tests/unit && vitest run tests/integration && playwright test"
    },
    "dependencies": {
        "@crayonai/react-core": "^0.7.6",
        "@crayonai/react-ui": "^0.8.31",
        "@crayonai/stream": "^0.6.4",
        "@fontsource/inter": "^5.2.8",
        "@fontsource/noto-sans-arabic": "^5.2.10",
        "@radix-ui/react-dialog": "^1.1.15",
        "@react-pdf/renderer": "^4.5.1",
        "@thesysai/genui-sdk": "^0.6.34",
        "@types/nodemailer": "^7.0.4",
        "@types/papaparse": "^5.5.2",
        "@types/uuid": "^10.0.0",
        "eventsource-parser": "^3.0.6",
        "next": "15.2.4",
        "nodemailer": "^7.0.11",
        "openai": "^4.91.1",
        "papaparse": "^5.5.3",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "uuid": "^13.0.0",
        "zod": "^4.1.13",
        "zod-to-json-schema": "^3.25.0",
        "zustand": "^5.0.8"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3",
        "@playwright/test": "^1.59.1",
        "@prisma/client": "^5.22.0",
        "@tailwindcss/oxide": "^4.1.3",
        "@tailwindcss/postcss": "^4",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@vitest/coverage-v8": "^1.6.0",
        "dotenv": "^17.2.3",
        "eslint": "^9",
        "eslint-config-next": "15.2.4",
        "lightningcss": "^1.29.2",
        "prisma": "^5.22.0",
        "tailwindcss": "^4",
        "ts-node": "^10.9.2",
        "typescript": "^5",
        "vitest": "^1.6.0"
    },
    "engines": {
        "node": ">=20.9.0"
    },
    "prisma": {
        "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
    }
}
