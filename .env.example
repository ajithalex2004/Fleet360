# =============================================================================
# XL AI Smart Mobility Platform — Environment Variables
# =============================================================================
# Copy this file to .env (development) or set these as deployment env vars
# in production. The .env file is gitignored. Validate via: import { env } from '@/lib/env'
# =============================================================================

# ── DATABASE (REQUIRED) ──────────────────────────────────────────────────────
# Production: managed Postgres (Neon / RDS / Supabase). Use a connection-pooler URL.
# Local dev:  postgresql://postgres:postgres@localhost:5432/mobility_dev
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Optional: separate URL for direct local DB access (skips pooler).
# LOCAL_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mobility_dev

# ── SESSION (REQUIRED in production) ─────────────────────────────────────────
# HMAC-SHA256 secret used to sign xl-session cookies. Min 32 chars.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-me-min-32-chars-random-secret-for-prod

# ── APPLICATION URL (REQUIRED) ───────────────────────────────────────────────
# Used in email links, approval URLs, and OAuth callbacks.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── AI / GENUI (REQUIRED for STS AI features) ────────────────────────────────
# OpenAI: powers Quotation Co-pilot, Document Auto-Classification, Contract Q&A.
OPENAI_API_KEY=sk-...

# Thesys C1: powers the generative-UI chat features.
THESYS_API_KEY=your-thesys-key

# ── EMAIL (one of these blocks required for dunning, alerts, notifications) ──
# Option A — SMTP (Mailgun, SendGrid SMTP, AWS SES SMTP, Office365):
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false                 # true only for port 465
SMTP_USER=
SMTP_PASS=
SMTP_FROM="XL AI Smart Mobility <noreply@your-domain.com>"
EMAIL_FROM="XL AI Smart Mobility <noreply@your-domain.com>"

# Option B — SendGrid HTTP API (alternative to SMTP):
# SENDGRID_API_KEY=

# ── WHATSAPP / TWILIO (optional — for STS notifications) ─────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ── MAPS (optional — for tracking views, route optimizer) ────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=
MAPBOX_TOKEN=
GOOGLE_MAPS_API_KEY=

# ── OPERATIONS ESCALATION (optional) ─────────────────────────────────────────
OPERATIONS_PHONE=
OPERATIONS_EMAIL=

# ── ADMIN BOOTSTRAP (REQUIRED to use /api/setup/super-admin) ─────────────────
# Random shared secret protecting the bootstrap endpoint. Used only at install.
SETUP_SECRET=change-me-random-secret

# ── ERROR TRACKING (optional but strongly recommended for production) ────────
# Get from https://sentry.io/ — leave blank to disable Sentry without errors.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# ── ENVIRONMENT FLAG ─────────────────────────────────────────────────────────
# Set automatically by Next.js / Vercel. Override only if needed.
# NODE_ENV=development
