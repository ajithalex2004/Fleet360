# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# backend runtime logs (regenerated each run)
backend/*.log
fleet360-dev*.log

# Go build artifacts
backend/*.exe
backend/cmd/*/*.exe

# env files (can opt-in for committing if needed)
.env*
# .env.example is the documented template — safe to commit (no real secrets)
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# Claude Code session state and worktrees
/.claude/

# Test artifacts
/playwright-report
/test-results

# Uploaded customer files (handled by storage adapter, not version control)
/public/uploads

# Accidental terminal-redirect outputs (0-byte files)
/npm
/p.$disconnect())
/template-c1@0.1.0
/playwright

