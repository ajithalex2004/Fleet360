// ============================================================
// RBAC - MULTI-TENANT ACCESS CONTROL
// ============================================================

model Tenant {
  id                 String         @id @default(uuid())
  createdAt          DateTime?      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime?      @updatedAt @map("updated_at") @db.Timestamptz(6)
  name               String
  code               String?        @unique
  plan               String?        @default("STANDARD") // TRIAL|STANDARD|PROFESSIONAL|ENTERPRISE
  industry           String?
  // Contact & identity
  domain             String?
  // CORS allow-list for this tenant: comma-separated list of browser origins
  // (scheme+host+port) that may call the Go backend on this tenant's behalf,
  // e.g. "https://fleet.clientA.com,https://staging.fleet.clientA.com". The
  // Go backend reads this column and merges it with the ALLOWED_ORIGINS env
  // var to build the live CORS allow-list. NULL means this tenant relies on
  // the env baseline only. Onboarding a tenant is a single UPDATE — no
  // recompile or container restart needed.
  allowedOrigins     String?        @map("allowed_origins")
  address            String?
  contactName        String?        @map("contact_name")
  contactEmail       String?        @map("contact_email")
  contactPhone       String?        @map("contact_phone")
  trn                String?        // UAE Tax Registration Number (shared across all branches)
  // Language configuration
  defaultLanguage    String?        @default("en") @map("default_language")
  supportedLanguages String?        @default("en") @map("supported_languages") // comma-sep: "en,ar"
  // Localised display name & description (JSON: {"en":"...","ar":"..."})
  localizedName      String?        @map("localized_name")
  localizedDesc      String?        @map("localized_desc")
  // Booking request-type whitelist (JSON array of type keys)
  bookingTypes       String?        @map("booking_types")
  isActive           Boolean?       @default(true) @map("is_active")
  modules            TenantModule[]
  roles              Role[]
  userTenants        UserTenant[]
  settings           TenantSettings?
  @@map("tenants")
}

model TenantModule {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  module    String
  isEnabled Boolean? @default(true) @map("is_enabled")
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  @@unique([tenantId, module])
  @@map("tenant_modules")
}

model Role {
  id          String           @id @default(uuid())
  createdAt   DateTime?        @default(now()) @map("created_at") @db.Timestamptz(6)
  tenantId    String?          @map("tenant_id")
  name        String
  code        String
  description String?
  isSystem    Boolean?         @default(false) @map("is_system")
  tenant      Tenant?          @relation(fields: [tenantId], references: [id])
  permissions RolePermission[]
  userTenants UserTenant[]
  @@unique([tenantId, code])
  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid())
  module      String
  action      String
  resource    String?          @default("*")
  label       String?
  description String?
  roles       RolePermission[]
  @@unique([module, action, resource])
  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserTenant {
  id        String    @id @default(uuid())
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  userId    String    @map("user_id")
  tenantId  String    @map("tenant_id")
  roleId    String    @map("role_id")
  isActive  Boolean?  @default(true) @map("is_active")
  user      User      @relation(fields: [userId], references: [id])
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  role      Role      @relation(fields: [roleId], references: [id])
  @@unique([userId, tenantId])
  @@map("user_tenants")
}

// ============================================================
// TENANT SETTINGS + VEHICLE GROUPS
// ============================================================

model TenantSettings {
  id        String   @id @default(uuid())
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime? @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenantId  String   @unique @map("tenant_id")

  // -- Trip Merging --
  tripMergingEnabled   Boolean  @default(false) @map("trip_merging_enabled")
  pickupMatchType      String?  @default("DISTANCE") @map("pickup_match_type")
  pickupDistanceKm     Decimal? @default(7)  @map("pickup_distance_km") @db.Decimal
  pickupTimeWindowMin  Int?     @default(30) @map("pickup_time_window_min")
  requireDropoffMatch  Boolean  @default(true) @map("require_dropoff_match")
  dropoffMatchType     String?  @default("DISTANCE") @map("dropoff_match_type")
  dropoffDistanceKm    Decimal? @default(25) @map("dropoff_distance_km") @db.Decimal
  dropoffTimeWindowMin Int?     @default(30) @map("dropoff_time_window_min")
  maxPassengers        Int?     @default(5)  @map("max_passengers")
  travelSpeedKmh       Decimal? @default(40) @map("travel_speed_kmh") @db.Decimal
  stopDurationMin      Int?     @default(10) @map("stop_duration_min")
  maxPickupDelayMin    Int?     @default(30) @map("max_pickup_delay_min")

  // -- Auto-Merge --
  autoMergeEnabled        Boolean @default(false) @map("auto_merge_enabled")
  triggerBeforePickupMin  Int?    @default(30) @map("trigger_before_pickup_min")
  lookAheadHours          Int?    @default(24) @map("look_ahead_hours")

  // -- Auto Dispatch --
  autoDispatchEnabled       Boolean @default(false) @map("auto_dispatch_enabled")
  maxDriverAttempts         Int?    @default(3)  @map("max_driver_attempts")
  driverResponseTimeoutMin  Int?    @default(6)  @map("driver_response_timeout_min")
  dispatchRadius            Decimal? @default(10) @map("dispatch_radius") @db.Decimal
  preferNearestDriver       Boolean  @default(true) @map("prefer_nearest_driver")

  // -- Route Optimization --
  routeOptimizationEnabled Boolean  @default(false) @map("route_optimization_enabled")
  routingEngine            String?  @default("GOOGLE_MAPS") @map("routing_engine")
  googleMapsApiKey         String?  @map("google_maps_api_key")
  maxApiCallsPerHour       Int?     @default(500)  @map("max_api_calls_per_hour")
  maxApiCallsPerDay        Int?     @default(5000) @map("max_api_calls_per_day")
  roadDistanceMultiplier   Decimal? @default(1.5)  @map("road_distance_multiplier") @db.Decimal
  fallbackToStraightLine   Boolean  @default(true) @map("fallback_to_straight_line")

  // -- Notifications --
  emailNotificationsEnabled Boolean @default(false) @map("email_notifications_enabled")
  smtpHost                  String? @map("smtp_host")
  smtpPort                  String? @default("587") @map("smtp_port")
  smtpUser                  String? @map("smtp_user")
  smtpPass                  String? @map("smtp_pass")
  smtpFromEmail             String? @map("smtp_from_email")
  smtpFromName              String? @map("smtp_from_name")
  smsNotificationsEnabled   Boolean @default(false) @map("sms_notifications_enabled")
  smsProvider               String? @map("sms_provider")
  smsApiKey                 String? @map("sms_api_key")
  smsFromNumber             String? @map("sms_from_number")
  pushNotificationsEnabled  Boolean @default(true) @map("push_notifications_enabled")
  notificationPreferences   String? @map("notification_preferences") // JSON: event->channels
  tripReminderTimingMin     Int?    @default(60) @map("trip_reminder_timing_min")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  @@map("tenant_settings")
}

// ============================================================
// CUSTOMER MANAGEMENT MODULE
// ============================================================

model Customer {
  id                         String   @id @default(uuid())
  createdAt                  DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                  DateTime? @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt                  DateTime? @map("deleted_at") @db.Timestamptz(6)
  tenantId                   String?   @map("tenant_id")

  // Basic Info
  customerCode               String?  @unique @map("customer_code")
  customerType               String   @map("customer_type") // INTERNAL|CORPORATE|INDIVIDUAL|WALK_IN|VIP
  priority                   String?  // LOW|MEDIUM|HIGH|VIP
  accountCode                String?  @map("account_code")
  tradeLicense               String?  @map("trade_license")
  mobileNumber               String?  @map("mobile_number")
  mobileCountryCode          String?  @default("+971") @map("mobile_country_code")
  email                      String?
  communicationLanguage      String?  @default("en") @map("communication_language")

  // Localized Name
  nameEn                     String   @map("name_en")
  nameAr                     String?  @map("name_ar")
  descriptionEn              String?  @map("description_en")
  descriptionAr              String?  @map("description_ar")

  // 3-Level Hierarchy
  regionId                   String?  @map("region_id")
  departmentId               String?  @map("department_id")
  unitId                     String?  @map("unit_id")

  // Contact & Address
  contactPerson              String?  @map("contact_person")
  contactPersonPhone         String?  @map("contact_person_phone")
  contactPersonEmail         String?  @map("contact_person_email")
  addressLine1               String?  @map("address_line1")
  addressLine2               String?  @map("address_line2")
  city                       String?
  state                      String?
  country                    String?  @default("UAE")
  poBox                      String?  @map("po_box")
  latitude                   Decimal? @db.Decimal
  longitude                  Decimal? @db.Decimal

  // Financial & Billing
  taxRegistrationNumber      String?  @map("tax_registration_number")
  taxApplicable              Boolean  @default(true) @map("tax_applicable")
  tollExempt                 Boolean  @default(false) @map("toll_exempt")
  creditLimit                Decimal? @map("credit_limit") @db.Decimal
  creditDays                 Int?     @map("credit_days")
  allowedPaymentMethods      String?  @map("allowed_payment_methods") // JSON array
  defaultPaymentMethod       String?  @map("default_payment_method")
  billingCycle               String?  @map("billing_cycle") // MONTHLY|QUARTERLY|ANNUALLY
  invoiceFrequency           String?  @map("invoice_frequency")
  invoiceDeliveryMethod      String?  @map("invoice_delivery_method") // EMAIL|PRINT|PORTAL
  paymentReminderDays        Int?     @map("payment_reminder_days")
  lateFeePercentage          Decimal? @map("late_fee_percentage") @db.Decimal
  autoInvoice                Boolean  @default(false) @map("auto_invoice")

  // Booking & Communication
  allowedWaitingTimeMin      Int?     @map("allowed_waiting_time_min")
  cancellationAllowedMin     Int?     @map("cancellation_allowed_min")
  allowedBookingModifications Int?    @map("allowed_booking_modifications")
  skipApproval               Boolean  @default(false) @map("skip_approval")
  preferredChannel           String?  @map("preferred_channel") // EMAIL|SMS|WHATSAPP|APP|PORTAL
  notificationEmail          String?  @map("notification_email")
  notificationSmsCode        String?  @default("+971") @map("notification_sms_code")
  notificationSms            String?  @map("notification_sms")
  marketingCommunications    Boolean  @default(false) @map("marketing_communications")
  bookingNotifications       Boolean  @default(true) @map("booking_notifications")

  // Status
  status                     String?  @default("ACTIVE") // ACTIVE|INACTIVE

  region                     CustomerHierarchy? @relation("CustomerRegion",     fields: [regionId],     references: [id])
  department                 CustomerHierarchy? @relation("CustomerDepartment", fields: [departmentId], references: [id])
  unit                       CustomerHierarchy? @relation("CustomerUnit",       fields: [unitId],       references: [id])
  documents                  CustomerDocument[]
  lessee                     Lessee?
  @@map("customers")
}

model CustomerHierarchy {
  id          String    @id @default(uuid())
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  tenantId    String?   @map("tenant_id")
  level       String    // REGION|DEPARTMENT|UNIT
  parentId    String?   @map("parent_id")
  name        String
  code        String?
  description String?
  isActive    Boolean?  @default(true) @map("is_active")

  parent      CustomerHierarchy?  @relation("HierarchyTree", fields: [parentId], references: [id])
  children    CustomerHierarchy[] @relation("HierarchyTree")

  customersAsRegion     Customer[] @relation("CustomerRegion")
  customersAsDepartment Customer[] @relation("CustomerDepartment")
  customersAsUnit       Customer[] @relation("CustomerUnit")
  @@map("customer_hierarchy")
}

model CustomerDocument {
  id          String    @id @default(uuid())
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  customerId  String    @map("customer_id")
  docName     String    @map("doc_name")
  docType     String?   @map("doc_type")
  fileName    String?   @map("file_name")
  fileUrl     String?   @map("file_url")
  fileSize    Int?      @map("file_size")
  mimeType    String?   @map("mime_type")
  uploadedBy  String?   @map("uploaded_by")
  notes       String?
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)
  customer    Customer  @relation(fields: [customerId], references: [id])

  @@map("customer_documents")
}

// ============================================================
// FINANCE PHASE 1 — OPERATIONAL FINANCE MODELS
// ============================================================

// ── PDC (Post-Dated Cheque) Register ────────────────────────
model FinancePdcCheque {
  id              String    @id @default(uuid())
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz(6)

  chequeNumber    String    @map("cheque_number")
  bankName        String    @map("bank_name")
  accountName     String?   @map("account_name")
  chequeDate      DateTime  @map("cheque_date") @db.Date
  amount          Decimal   @db.Decimal(15, 2)
  currency        String    @default("AED")

  // INCOMING (from client) | OUTGOING (to supplier)
  direction       String    @default("INCOMING")
  clientName      String?   @map("client_name")
  clientRef       String?   @map("client_ref")   // invoice ID, contract ID etc.

  // HELD | DEPOSITED | CLEARED | BOUNCED | CANCELLED | RETURNED
  status          String    @default("HELD")
  depositedAt     DateTime? @map("deposited_at") @db.Timestamptz(6)
  clearedAt       DateTime? @map("cleared_at") @db.Timestamptz(6)
  bouncedAt       DateTime? @map("bounced_at") @db.Timestamptz(6)
  bounceReason    String?   @map("bounce_reason")

  linkedInvoiceId String?   @map("linked_invoice_id")
  notes           String?
  createdBy       String?   @map("created_by")

  @@map("finance_pdc_cheques")
}

// ── Expense Management ───────────────────────────────────────
model FinanceExpense {
  id              String    @id @default(uuid())
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz(6)

  expenseNo       String    @unique @map("expense_no")
  category        String    // FUEL|TOLL|MAINTENANCE|INSURANCE|DRIVER_ALLOWANCE|OFFICE|REPAIRS|OTHER
  subCategory     String?   @map("sub_category")
  description     String
  amount          Decimal   @db.Decimal(15, 2)
  currency        String    @default("AED")
  vatAmount       Decimal?  @default(0) @map("vat_amount") @db.Decimal(15, 2)
  totalAmount     Decimal   @map("total_amount") @db.Decimal(15, 2)

  expenseDate     DateTime  @map("expense_date") @db.Date
  paymentMethod   String?   @map("payment_method") // CASH|BANK_TRANSFER|CHEQUE|CARD|PDC
  referenceNo     String?   @map("reference_no")

  // DRAFT | SUBMITTED | APPROVED | REJECTED | PAID
  status          String    @default("DRAFT")

  vehicleId       String?   @map("vehicle_id")
  driverId        String?   @map("driver_id")
  costCentre      String?   @map("cost_centre") // RAC|LEASING|LOGISTICS|STAFF|SCHOOL|ADMIN

  receiptUrl      String?   @map("receipt_url")
  submittedBy     String?   @map("submitted_by")
  submittedAt     DateTime? @map("submitted_at") @db.Timestamptz(6)
  approvedBy      String?   @map("approved_by")
  approvedAt      DateTime? @map("approved_at") @db.Timestamptz(6)
  rejectedBy      String?   @map("rejected_by")
  rejectedAt      DateTime? @map("rejected_at") @db.Timestamptz(6)
  rejectionReason String?   @map("rejection_reason")
  paidAt          DateTime? @map("paid_at") @db.Timestamptz(6)
  notes           String?

  @@map("finance_expenses")
}

// ── Tax Categories ───────────────────────────────────────────
model FinanceTaxCategory {
  id              String    @id @default(uuid())
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  code            String    @unique  // STANDARD|ZERO|EXEMPT|OUT_OF_SCOPE
  name            String
  rate            Decimal   @db.Decimal(5, 2)  // 5.00, 0.00 etc.
  description     String?
  isDefault       Boolean   @default(false) @map("is_default")
  isActive        Boolean   @default(true)  @map("is_active")
  ftaCode         String?   @map("fta_code") // FTA box codes for VAT return

  @@map("finance_tax_categories")
}

// ── VAT Audit Log ────────────────────────────────────────────
model FinanceVatAuditLog {
  id              String    @id @default(uuid())
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  action          String    // CALCULATE|SUBMIT|AMEND|PAY|REVERSE
  entityType      String?   @map("entity_type") // VAT_RETURN|INVOICE|CREDIT_NOTE
  entityId        String?   @map("entity_id")
  performedBy     String?   @map("performed_by")
  details         Json?
  ipAddress       String?   @map("ip_address")
  notes           String?

  @@map("finance_vat_audit_logs")
}

// ── Enhanced Credit Notes ────────────────────────────────────
model FinanceCreditNote {
  id              String    @id @default(uuid())
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz(6)

  cnNumber        String    @unique @map("cn_number")
  originalInvoiceId String? @map("original_invoice_id")  // finance_invoices.id
  originalInvoiceNo String? @map("original_invoice_no")

  clientName      String    @map("client_name")
  clientEmail     String?   @map("client_email")
  module          String?   // RAC|LEASING|LOGISTICS|STAFF|SCHOOL|GENERAL

  // BILLING_ERROR|SERVICE_FAILURE|OVERPAYMENT|CONTRACT_CANCELLATION|RATE_ADJUSTMENT|OTHER
  reasonCode      String    @map("reason_code")
  reasonDetail    String?   @map("reason_detail")

  lineItems       Json?     @map("line_items")  // [{description, quantity, unitPrice, vatRate, vatAmount, total}]
  subtotal        Decimal   @db.Decimal(15, 2)
  vatAmount       Decimal   @default(0) @map("vat_amount") @db.Decimal(15, 2)
  totalAmount     Decimal   @map("total_amount") @db.Decimal(15, 2)
  currency        String    @default("AED")

  issueDate       DateTime  @map("issue_date") @db.Date

  // DRAFT | ISSUED | APPLIED | REFUNDED | VOIDED
  status          String    @default("DRAFT")

  appliedAmount   Decimal?  @default(0) @map("applied_amount") @db.Decimal(15, 2)
  refundedAt      DateTime? @map("refunded_at") @db.Timestamptz(6)
  refundMethod    String?   @map("refund_method")

  issuedBy        String?   @map("issued_by")
  approvedBy      String?   @map("approved_by")
  notes           String?

  @@map("finance_credit_notes")
}

// ── Collection Cases / Dunning ───────────────────────────────
model FinanceCollectionCase {
  id              String    @id @default(uuid())
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz(6)

  caseNo          String    @unique @map("case_no")
  invoiceId       String    @map("invoice_id")  // finance_invoices.id
  invoiceNo       String    @map("invoice_no")
  clientName      String    @map("client_name")
  clientEmail     String?   @map("client_email")
  clientPhone     String?   @map("client_phone")

  invoiceAmount   Decimal   @map("invoice_amount") @db.Decimal(15, 2)
  paidAmount      Decimal   @default(0) @map("paid_amount") @db.Decimal(15, 2)
  outstandingAmount Decimal @map("outstanding_amount") @db.Decimal(15, 2)
  dueDate         DateTime  @map("due_date") @db.Date
  daysOverdue     Int       @default(0) @map("days_overdue")

  // OPEN | CONTACTED | PROMISED | ESCALATED | LEGAL | SETTLED | WRITTEN_OFF | CLOSED
  status          String    @default("OPEN")

  // DUNNING_1 | DUNNING_2 | DUNNING_3 | FINAL_NOTICE | LEGAL_NOTICE
  dunningStage    String?   @map("dunning_stage")
  lastContactDate DateTime? @map("last_contact_date") @db.Date
  promisedPayDate DateTime? @map("promised_pay_date") @db.Date
  promisedAmount  Decimal?  @map("promised_amount") @db.Decimal(15, 2)

  assignedTo      String?   @map("assigned_to")
  notes           String?
  timeline        Json?     // [{date, action, by, note}]

  @@map("finance_collection_cases")
}

// ── Bank Accounts ────────────────────────────────────────────
model FinanceBankAccount {
  id              String    @id @default(uuid())
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz(6)

  bankName        String    @map("bank_name")
  accountName     String    @map("account_name")
  accountNumber   String    @map("account_number")
  iban            String?
  currency        String    @default("AED")
  branchName      String?   @map("branch_name")
  swiftCode       String?   @map("swift_code")
  isDefault       Boolean   @default(false) @map("is_default")
  isActive        Boolean   @default(true)  @map("is_active")

  currentBalance  Decimal?  @default(0) @map("current_balance") @db.Decimal(15, 2)
  lastReconciledAt DateTime? @map("last_reconciled_at") @db.Timestamptz(6)

  statements      FinanceBankStatement[]

  @@map("finance_bank_accounts")
}

// ── Bank Statements ──────────────────────────────────────────
model FinanceBankStatement {
  id              String    @id @default(uuid())
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  bankAccountId   String    @map("bank_account_id")
  bankAccount     FinanceBankAccount @relation(fields: [bankAccountId], references: [id])

  statementDate   DateTime  @map("statement_date") @db.Date
  periodStart     DateTime  @map("period_start") @db.Date
  periodEnd       DateTime  @map("period_end") @db.Date
  openingBalance  Decimal   @map("opening_balance") @db.Decimal(15, 2)
  closingBalance  Decimal   @map("closing_balance") @db.Decimal(15, 2)
  importedBy      String?   @map("imported_by")
  notes           String?

  lines           FinanceBankStatementLine[]

  @@map("finance_bank_statements")
}

// ── Bank Statement Lines ─────────────────────────────────────
model FinanceBankStatementLine {
  id              String    @id @default(uuid())
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  statementId     String    @map("statement_id")
  statement       FinanceBankStatement @relation(fields: [statementId], references: [id], onDelete: Cascade)

  txnDate         DateTime  @map("txn_date") @db.Date
  valueDate       DateTime? @map("value_date") @db.Date
  description     String
  reference       String?
  debit           Decimal?  @db.Decimal(15, 2)
  credit          Decimal?  @db.Decimal(15, 2)
  balance         Decimal?  @db.Decimal(15, 2)

  // UNMATCHED | MATCHED | EXCLUDED
  matchStatus     String    @default("UNMATCHED") @map("match_status")
  matchedPaymentId String?  @map("matched_payment_id")
  matchedAt       DateTime? @map("matched_at") @db.Timestamptz(6)
  matchedBy       String?   @map("matched_by")
  notes           String?

  @@map("finance_bank_statement_lines")
}
