  nameAr                String?   @map("name_ar")
  description           String?
  category              String?
  pricingType           String    @map("pricing_type")
  unitPrice             Decimal   @map("unit_price") @db.Decimal
  currency              String?   @default("AED")
  applicableCategories  String?   @map("applicable_categories")
  isActive              Boolean?  @default(true)
  sortOrder             Int?      @default(0)
  notes                 String?
  @@index([deletedAt], map: "idx_rental_ancillaries_deleted_at")
  @@map("rental_ancillaries")
