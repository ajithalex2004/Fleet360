// -- Enhanced Rate Engine ---------------------------------------
model PricingRule {
  id                  String    @id @default(uuid())
  createdAt           DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime? @updatedAt @map("updated_at") @db.Timestamptz(6)
  name                String?                                     // friendly label
  vehicleCategory     String    @map("vehicle_category")          // ECONOMY|COMPACT|SUV|LUXURY|VAN|TRUCK

  // Base rates
  baseDailyRate       Decimal   @map("base_daily_rate") @db.Decimal
  baseKmRate          Decimal?  @map("base_km_rate") @db.Decimal
  baseHourlyRate      Decimal?  @map("base_hourly_rate") @db.Decimal
  weeklyRate          Decimal?  @map("weekly_rate") @db.Decimal
  monthlyRate         Decimal?  @map("monthly_rate") @db.Decimal
  weekendDailyRate    Decimal?  @map("weekend_daily_rate") @db.Decimal

  // Seasonal / date range
  seasonFrom          DateTime? @map("season_from") @db.Timestamptz(6)
  seasonTo            DateTime? @map("season_to") @db.Timestamptz(6)
  multiplier          Decimal?  @default(1) @db.Decimal

  // Multi-currency
  currency            String?   @default("AED")
  exchangeRateToAed   Decimal?  @default(1) @map("exchange_rate_to_aed") @db.Decimal

  // Customer segmentation
  customerType        String?   @map("customer_type")     // INDIVIDUAL|CORPORATE|AIRLINE|FREQUENT_FLYER|INSURANCE
  corporateAccountId  String?   @map("corporate_account_id")
  airlineCode         String?   @map("airline_code")
  frequentFlyerProg   String?   @map("frequent_flyer_prog")
  creditCardType      String?   @map("credit_card_type")  // VISA|MASTERCARD|AMEX|ANY

  // Location-based pricing
  pickupLocationCode  String?   @map("pickup_location_code")
  dropoffLocationCode String?   @map("dropoff_location_code")
  isAirportRate       Boolean?  @default(false) @map("is_airport_rate")
  isDomestic          Boolean?  @default(true)  @map("is_domestic")

  // Channel pricing
  channel             String?   // DIRECT|CORPORATE|AGENCY|ONLINE|ALL
  onlineDiscount      Decimal?  @default(0) @map("online_discount") @db.Decimal // % off

  // Grace period & late fees
  gracePeriodMin      Int?      @default(30) @map("grace_period_min")  // free minutes after agreed return
  lateFeePerHour      Decimal?  @map("late_fee_per_hour") @db.Decimal
  lateFeeCap          Decimal?  @map("late_fee_cap") @db.Decimal        // max late charge per day

  // Minimum rental
  minRentalDays       Int?      @default(1) @map("min_rental_days")
  minRentalHours      Int?      @default(0) @map("min_rental_hours")

  // Insurance & coverage options (stored as JSON array)
  insurancePlans      String?   @map("insurance_plans")  // JSON: [{code, name, dailyRate, coverage}]

  // Promotion
  promoCode           String?   @map("promo_code")
  promoDiscountPct    Decimal?  @map("promo_discount_pct") @db.Decimal
  promoValidFrom      DateTime? @map("promo_valid_from") @db.Timestamptz(6)
  promoValidTo        DateTime? @map("promo_valid_to") @db.Timestamptz(6)
  promoMaxUses        Int?      @map("promo_max_uses")
  promoUsedCount      Int?      @default(0) @map("promo_used_count")

  // Free km / included km
  includedKmPerDay    Int?      @map("included_km_per_day")
  excessKmRate        Decimal?  @map("excess_km_rate") @db.Decimal

  // Priority (higher wins when multiple rules match)
  priority            Int?      @default(0)
  isActive            Boolean?  @default(true) @map("is_active")
  notes               String?

  @@index([vehicleCategory], map: "idx_pricing_rules_vehicle_category")
  @@index([customerType], map: "idx_pricing_rules_customer_type")
  @@index([channel], map: "idx_pricing_rules_channel")
  @@index([promoCode], map: "idx_pricing_rules_promo_code")
  @@index([isActive], map: "idx_pricing_rules_is_active")
  @@map("pricing_rules")
}

// Yield-management event calendar — applied as a multiplier layer on top of
// the base rate. Used for festival surcharges (DSF, Eid, F1) and demand-low
// discounts (deep summer).
model RateEvent {
  id                    String    @id @default(uuid())
  createdAt             DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime? @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt             DateTime? @map("deleted_at") @db.Timestamptz(6)
  eventCode             String    @unique @map("event_code")
  name                  String
  description           String?
  dateFrom              DateTime  @map("date_from") @db.Timestamptz(6)
  dateTo                DateTime  @map("date_to") @db.Timestamptz(6)
  multiplier            Decimal   @db.Decimal
  applicableCategories  String?   @map("applicable_categories")
  applicableChannels    String?   @map("applicable_channels")
  priority              Int?      @default(0)
  isActive              Boolean?  @default(true)
  notes                 String?
  @@index([isActive, dateFrom, dateTo], map: "idx_rate_events_active_dates")
  @@index([deletedAt], map: "idx_rate_events_deleted_at")
  @@map("rate_events")
}

// Rate quote snapshot -- saved when a booking is created
model RentalRateQuote {
  id                  String    @id @default(uuid())
  createdAt           DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  bookingId           String?   @map("booking_id")
  vehicleCategory     String    @map("vehicle_category")
  pickupDate          DateTime  @map("pickup_date") @db.Timestamptz(6)
  dropoffDate         DateTime  @map("dropoff_date") @db.Timestamptz(6)
  totalDays           Int       @map("total_days")
  totalHours          Int?      @map("total_hours")
  appliedRuleId       String?   @map("applied_rule_id")
  currency            String?   @default("AED")
  baseRentalCharge    Decimal   @map("base_rental_charge") @db.Decimal
  insurancePlanCode   String?   @map("insurance_plan_code")
  insuranceCharge     Decimal?  @default(0) @map("insurance_charge") @db.Decimal
  extras              String?   // JSON [{name, amount}]
  discountPct         Decimal?  @default(0) @map("discount_pct") @db.Decimal
  discountAmount      Decimal?  @default(0) @map("discount_amount") @db.Decimal
  taxPct              Decimal?  @default(5) @map("tax_pct") @db.Decimal   // UAE VAT
  taxAmount           Decimal?  @default(0) @map("tax_amount") @db.Decimal
  totalAmount         Decimal   @map("total_amount") @db.Decimal
  breakdown           String?   // JSON line-by-line detail
  expiresAt           DateTime? @map("expires_at") @db.Timestamptz(6)
  @@index([bookingId], map: "idx_rental_rate_quotes_booking_id")
  @@map("rental_rate_quotes")
}

model RentalAgreement {
  id                  String        @id @default(uuid())
  createdAt           DateTime?     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime?     @updatedAt @map("updated_at") @db.Timestamptz(6)
  agreementNo         String?       @unique @map("agreement_no")
  bookingId           String        @unique @map("booking_id")
  customerId          String        @map("customer_id")
  vehicleId           String?       @map("vehicle_id")
  startDate           DateTime      @map("start_date") @db.Timestamptz(6)
  endDate             DateTime      @map("end_date") @db.Timestamptz(6)
  dailyRate           Decimal?      @map("daily_rate") @db.Decimal
  totalAmount         Decimal?      @map("total_amount") @db.Decimal
  currency            String?       @default("AED")
  securityDeposit     Decimal?      @map("security_deposit") @db.Decimal
  depositStatus       String?       @default("PENDING") @map("deposit_status") // PENDING|PAID|REFUNDED
  mileageIn           Int?          @map("mileage_in")
  mileageOut          Int?          @map("mileage_out")
  fuelIn              Int?          @map("fuel_in")
  fuelOut             Int?          @map("fuel_out")
  terms               String?
  status              String?       @default("DRAFT") // DRAFT|ACTIVE|COMPLETED|CANCELLED
  signedAt            DateTime?     @map("signed_at") @db.Timestamptz(6)
  signedBy            String?       @map("signed_by")

  // Branch tracking (open in one branch, close in another)
  openBranchId        String?       @map("open_branch_id")
  closeBranchId       String?       @map("close_branch_id")

  // Source tracking
  sourceType          String?       @default("BOOKING") @map("source_type") // BOOKING|QUOTATION|WALK_IN|EXTENSION
  rateQuoteId         String?       @map("rate_quote_id")
  insurancePlanCode   String?       @map("insurance_plan_code")
  insuranceDailyRate  Decimal?      @map("insurance_daily_rate") @db.Decimal

  // Commercial customer
  isCorporate         Boolean?      @default(false) @map("is_corporate")
  corporateAccountId  String?       @map("corporate_account_id")
  authorizationCode   String?       @map("authorization_code")
  creditCardLast4     String?       @map("credit_card_last4")
  creditCardToken     String?       @map("credit_card_token") // tokenized -- never store raw card

  // Remarks
  remarks             String?
  language            String?       @default("en") // en|ar

  booking             RentalBooking @relation(fields: [bookingId], references: [id])
  payments            RentalPayment[]
  extensions          RentalExtension[]
  charges             RentalAdditionalCharge[]
  vehicleExchanges    RentalVehicleExchange[]
  invoices            RentalInvoice[]

  @@index([customerId], map: "idx_rental_agreements_customer_id")
  @@index([vehicleId], map: "idx_rental_agreements_vehicle_id")
  @@index([status], map: "idx_rental_agreements_status")
  @@index([openBranchId], map: "idx_rental_agreements_open_branch_id")
  @@map("rental_agreements")
}

// Mid-rental vehicle exchange
