  securityDeposit   Decimal?        @map("security_deposit") @db.Decimal
  currency          String?         @default("AED")
  status            String?         @default("DRAFT") // DRAFT|APPROVED|ACTIVE|EXTENDED|TERMINATED|CLOSED
  notes             String?
  lessee            Lessee          @relation(fields: [lesseeId], references: [id])
  payments          LeasePayment[]
  returns           LeaseVehicleReturn[]
  @@index([lesseeId], map: "idx_lease_contracts_lessee_id")
  @@index([vehicleId], map: "idx_lease_contracts_vehicle_id")
  @@index([status], map: "idx_lease_contracts_status")
  @@index([deletedAt], map: "idx_lease_contracts_deleted_at")
