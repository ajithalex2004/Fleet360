// -- Rental Invoicing ------------------------------------------
model RentalInvoice {
  id                  String          @id @default(uuid())
  createdAt           DateTime?       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime?       @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt           DateTime?       @map("deleted_at") @db.Timestamptz(6)

  invoiceNo           String          @unique @map("invoice_no")
  agreementId         String          @map("agreement_id")
  customerId          String          @map("customer_id")

  // Invoice type
  invoiceType         String?         @default("STANDARD") @map("invoice_type")
  // STANDARD | PRE_BILLING | MONTHLY | COMBINATION | CREDIT_NOTE

  // Dates
  invoiceDate         DateTime        @map("invoice_date") @db.Timestamptz(6)
  dueDate             DateTime        @map("due_date") @db.Timestamptz(6)
  periodFrom          DateTime?       @map("period_from") @db.Timestamptz(6)
  periodTo            DateTime?       @map("period_to") @db.Timestamptz(6)

  // Amounts
  currency            String?         @default("AED")
  subtotal            Decimal         @db.Decimal
  discountAmount      Decimal?        @default(0) @map("discount_amount") @db.Decimal
  taxablAmount        Decimal?        @default(0) @map("taxable_amount") @db.Decimal
  taxRate             Decimal?        @default(5) @map("tax_rate") @db.Decimal   // UAE VAT 5%
  taxAmount           Decimal?        @default(0) @map("tax_amount") @db.Decimal
  totalAmount         Decimal         @map("total_amount") @db.Decimal
  paidAmount          Decimal?        @default(0) @map("paid_amount") @db.Decimal
  balanceDue          Decimal?        @map("balance_due") @db.Decimal

  // Status
  status              String?         @default("DRAFT") @map("status")
  // DRAFT | SENT | PARTIALLY_PAID | PAID | OVERDUE | VOID | DISPUTED

  // Corporate invoicing
  isCorporate         Boolean?        @default(false) @map("is_corporate")
  corporateAccountId  String?         @map("corporate_account_id")
  billingMode         String?         @default("SEPARATE") @map("billing_mode")  // SEPARATE|COMBINED

  // Payment & collection
  paymentTermsDays    Int?            @default(30) @map("payment_terms_days")
  sentAt              DateTime?       @map("sent_at") @db.Timestamptz(6)
  paidAt              DateTime?       @map("paid_at") @db.Timestamptz(6)
  voidedAt            DateTime?       @map("voided_at") @db.Timestamptz(6)
  voidReason          String?         @map("void_reason")

  // Reference to parent invoice (for credit notes)
  parentInvoiceId     String?         @map("parent_invoice_id")

  notes               String?
  internalNotes       String?         @map("internal_notes")

  agreement           RentalAgreement @relation(fields: [agreementId], references: [id])
  lineItems           RentalInvoiceLineItem[]
  receiptPayments     RentalInvoicePayment[]

  @@index([agreementId], map: "idx_rental_invoices_agreement_id")
  @@index([customerId], map: "idx_rental_invoices_customer_id")
  @@index([status], map: "idx_rental_invoices_status")
  @@index([dueDate], map: "idx_rental_invoices_due_date")
  @@index([deletedAt], map: "idx_rental_invoices_deleted_at")
  @@index([corporateAccountId], map: "idx_rental_invoices_corporate_account_id")
  @@map("rental_invoices")
}

model RentalInvoiceLineItem {
  id              String          @id @default(uuid())
  createdAt       DateTime?       @default(now()) @map("created_at") @db.Timestamptz(6)
  invoiceId       String          @map("invoice_id")
  lineType        String          @map("line_type")
  // RENTAL|INSURANCE|FUEL|EXTRA_KM|DAMAGE|TRAFFIC_FINE|CLEANING|EXTENSION|DEPOSIT|DISCOUNT|TAX|OTHER
  description     String
  quantity        Decimal         @db.Decimal
  unitPrice       Decimal         @map("unit_price") @db.Decimal
  unitLabel       String?         @default("day") @map("unit_label") // day|km|hour|flat
  discountPct     Decimal?        @default(0) @map("discount_pct") @db.Decimal
  taxable         Boolean?        @default(true)
  amount          Decimal         @db.Decimal                         // qty * unitPrice - discount
  sortOrder       Int?            @default(0) @map("sort_order")
  referenceId     String?         @map("reference_id")               // chargeId, trafficFineId etc.
  invoice         RentalInvoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  @@index([invoiceId], map: "idx_rental_invoice_line_items_invoice_id")
  @@map("rental_invoice_line_items")
}

// Payment receipts against an invoice
model RentalInvoicePayment {
  id              String          @id @default(uuid())
  createdAt       DateTime?       @default(now()) @map("created_at") @db.Timestamptz(6)
  invoiceId       String          @map("invoice_id")
  amount          Decimal         @db.Decimal
  currency        String?         @default("AED")
  paymentMethod   String?         @map("payment_method") // CASH|CARD|BANK|CHEQUE|ONLINE
  referenceNo     String?         @map("reference_no")
  receiptNo       String?         @unique @map("receipt_no")
  paidAt          DateTime        @map("paid_at") @db.Timestamptz(6)
  receivedBy      String?         @map("received_by")
  notes           String?
  invoice         RentalInvoice   @relation(fields: [invoiceId], references: [id])
  @@index([invoiceId], map: "idx_rental_invoice_payments_invoice_id")
  @@map("rental_invoice_payments")
}

