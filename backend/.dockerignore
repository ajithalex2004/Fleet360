# Local-only files that have no business landing in the build context.
# Keep this list aligned with what the build actually needs: go.mod, go.sum,
# *.go, seed/, handlers/, models/, database/, uploads/.

# Editor / OS noise
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Local dev artefacts
*.log
*.exe
backend
backend.exe

# Test / debug command binaries — built ad-hoc by developers, never part of
# the production image.
cmd/

# Local data dumps — generated by tools, not source.
*.json
!package.json
maintenance_requests.json
response.json
response_2.json
inspect_vehicle_data.go
cleanup_vehicles.go

# CI/Operator scripts
*.ps1
test_endpoints.ps1

# Git / Docker metadata (Docker sets its own context already)
.git/
.gitignore
.dockerignore
Dockerfile
